// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FormaPagamento {
  PIX
  DINHEIRO
  CARTAO
  BOLETO
  OUTROS
}

enum StatusVenda {
  CONCLUIDA
  CANCELADA
}

enum Role {
  ADMIN
}

model Usuario {
  id         String   @id @default(uuid())
  nome       String
  email      String   @unique
  senhaHash  String
  role       Role     @default(ADMIN)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("usuarios")
}

model Produto {
  id             String      @id @default(uuid())
  nome           String
  sku            String      @unique
  categoria      String
  precoVenda     Decimal     @db.Decimal(10, 2)
  custo          Decimal?    @db.Decimal(10, 2)
  estoqueAtual   Int         @default(0)
  estoqueMinimo  Int?        @default(0)
  ativo          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  itensVenda  ItemVenda[]

  @@map("produtos")
}

model Cliente {
  id          String   @id @default(uuid())
  nome        String
  telefone    String
  email       String?
  cpfCnpj     String?
  endereco    String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendas Venda[]

  @@map("clientes")
}

model Venda {
  id             String         @id @default(uuid())
  clienteId      String
  dataVenda      DateTime       @default(now())
  formaPagamento FormaPagamento
  status         StatusVenda    @default(CONCLUIDA)
  subtotal       Decimal        @db.Decimal(10, 2)
  desconto       Decimal        @default(0) @db.Decimal(10, 2)
  total          Decimal        @db.Decimal(10, 2)
  observacoes    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  cliente    Cliente     @relation(fields: [clienteId], references: [id])
  itens      ItemVenda[]

  @@map("vendas")
}

model ItemVenda {
  id            String  @id @default(uuid())
  vendaId       String
  produtoId     String
  quantidade    Int
  valorUnitario Decimal @db.Decimal(10, 2)
  totalItem     Decimal @db.Decimal(10, 2)

  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])

  @@map("itens_venda")
}
